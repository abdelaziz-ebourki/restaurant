  "item": [
    {
      "name": "Ajouter Plat",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code est 200 (OK)\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Le plat a bien un ID généré\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.id).to.not.be.null;\r",
              "});\r",
              "\r",
              "pm.test(\"Vérification du filtrage : coutIngredients doit être ABSENT\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.coutIngredients).to.be.undefined;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disabledSystemHeaders": {}
      },
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\"nom\": \"Salade César\", \"calories\": 450, \"prix\": 12.0, \"coutIngredients\": 4.5}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:8080/plats",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "plats"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Healthy",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code est 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Vérification de la règle métier : Toutes les calories < 500\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    jsonData.forEach(function(plat) {\r",
              "        pm.expect(plat.calories).to.be.below(500);\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/plats/healthy",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "plats",
            "healthy"
          ]
        }
      },
      "response": []
    },
